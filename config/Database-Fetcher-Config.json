{
  "globalStartDate": "1999-12-01",
  "providers": {
    "Binance": {
      "type": "http",
      "baseUrl": "https://api.binance.com",
      "overrideStartDate": "2017-08-01",
      "auth": null,
      "requestsPerSecond": 2,
      "maxRetries": 3,
      "pagination": {
        "strategy": "time-cursor",
        "limitParam": "limit",
        "maxLimit": 1000,
        "startParam": "startTime",
        "endParam": "endTime",
        "cursorExtractPath": "last_item_index_6",
        "cursorModifier": "add_1ms",
        "dateExtractPath": 0,
        "dateFormat": "unix-ms"
      }
    },
    "FiscalData": {
      "type": "http",
      "baseUrl": "https://api.fiscaldata.treasury.gov/services/api/fiscal_service",
      "auth": null,
      "responseExtractPath": "data",
      "pagination": {
        "strategy": "page-number",
        "limitParam": "page[size]",
        "maxLimit": 10000,
        "pageParam": "page[number]",
        "startPage": 1,
        "incrementalFilterParam": "filter",
        "incrementalFilterTemplate": "record_date:gte:{date}",
        "dateExtractPath": "record_date",
        "dateFormat": "YYYY-MM-DD"
      }
    },
    "FRED": {
      "type": "http",
      "baseUrl": "https://api.stlouisfed.org",
      "auth": {
        "type": "query",
        "key": "api_key",
        "envVar": "FRED_API_KEY"
      },
      "responseExtractPath": "observations",
      "pagination": {
        "strategy": "date-range",
        "limitParam": "limit",
        "maxLimit": 100000,
        "startParam": "observation_start",
        "endParam": "observation_end",
        "dateExtractPath": "date",
        "dateFormat": "YYYY-MM-DD"
      }
    },
    "Tiingo": {
      "type": "http",
      "baseUrl": "https://api.tiingo.com",
      "auth": {
        "type": "header",
        "key": "Authorization",
        "prefix": "Token ",
        "envVar": "TIINGO_API_KEY"
      },
      "pagination": {
        "strategy": "date-range",
        "startParam": "startDate",
        "endParam": "endDate",
        "dateExtractPath": "date",
        "dateFormat": "YYYY-MM-DD"
      }
    },
    "YahooFinance": {
      "type": "package",
      "pagination": {
        "strategy": "package-internal",
        "startParam": "period1",
        "dateExtractPath": "date",
        "dateFormat": "YYYY-MM-DD"
      }
    }
  },
  "tasks": [
